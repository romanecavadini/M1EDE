# Comparative Analysis: Single Client vs. Type Average
# This function allows for a direct comparison of a specific client's consumption pattern against the average consumption of their assigned consumer type ('Principale' or 'Secondaire'). This helps in understanding how an individual client's behavior deviates from or conforms to the typical pattern of their group.

import matplotlib.pyplot as plt
import pandas as pd

def plot_single_client_vs_type_average(df_daily, df_results, client_id, resample_freq='D', title_suffix=""):
    """
    Plots the consumption curve for a single client and compares it to the average
    consumption of their assigned consumer type.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        df_results (pd.DataFrame): DataFrame with 'id' as index and 'consumer_type' as a column.
        client_id (int or str): The ID of the client for whom to plot the consumption.
        resample_freq (str): The frequency to resample the data (e.g., 'H', 'D', 'W', 'M').
        title_suffix (str): An optional suffix for the plot title.
    """
    if client_id not in df_daily.index:
        print(f"Client ID {client_id} not found in the data.")
        return

    if client_id not in df_results.index:
        print(f"Client ID {client_id} not found in df_results to determine consumer type.")
        return

    consumer_type_label = df_results.loc[client_id, 'consumer_type']

    # Get single client consumption
    single_client_consumption = df_daily.loc[client_id]
    single_client_consumption.index = pd.to_datetime(single_client_consumption.index)
    resampled_client_consumption = single_client_consumption.resample(resample_freq).sum()

    # Get average consumption for the client's consumer type
    target_ids = df_results[df_results['consumer_type'] == consumer_type_label].index.tolist()
    # Exclude the current client from the average to make it a true group average
    target_ids_for_avg = [idx for idx in target_ids if idx != client_id]

    if not target_ids_for_avg:
        print(f"Cannot calculate average for type {consumer_type_label} without other clients.")
        return

    type_average_consumption_df = df_daily.loc[target_ids_for_avg]

    try:
        type_average_consumption_df.columns = pd.to_datetime(type_average_consumption_df.columns)
    except Exception as e:
        print(f"Warning: Could not convert df_daily columns to datetime for type average: {e}")

    type_avg_consumption_series = type_average_consumption_df.stack().rename('value')
    if isinstance(type_avg_consumption_series.index, pd.MultiIndex):
        type_avg_consumption_series.index = type_avg_consumption_series.index.map(lambda x: x[1])
    type_avg_consumption_series.index = pd.to_datetime(type_avg_consumption_series.index)

    resampled_type_average = type_avg_consumption_series.resample(resample_freq).mean()

    # Plotting
    plt.figure(figsize=(14, 7))
    plt.plot(resampled_client_consumption.index, resampled_client_consumption.values,
             label=f'Client {client_id} (Type: {consumer_type_label})', color='blue', alpha=0.8)
    plt.plot(resampled_type_average.index, resampled_type_average.values,
             label=f'Average {consumer_type_label} Type', color='red', linestyle='--', alpha=0.7)

    plt.title(f'Client {client_id} Consumption vs. {consumer_type_label} Type Average ({resample_freq} Aggregation) {title_suffix}')
    plt.xlabel('Date')
    plt.ylabel('Consumption (Value)')
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()

# --- Example Usage for a single client vs. type average ---
example_client_id = df_daily.index[0] # Using the first client ID as an example

print(f"\nPlotting consumption for client {example_client_id} against their type average:")
plot_single_client_vs_type_average(df_daily, df_results, example_client_id, resample_freq='D', title_suffix="Daily")
