#Enhanced Consumption Curve Comparison (Aggregation & Error Bands)

#This section introduces an improved plot_multiple_consumption_curves function. It extends the previous version by allowing you to choose different aggregation methods (like mean, median, sum, std) and visualize the standard deviation as error bands, providing more detailed insights into consumption variability.

import matplotlib.pyplot as plt
import pandas as pd

def plot_multiple_consumption_curves_enhanced(df_daily, df_results, consumer_type_labels, resample_freq='h', colors=None, title="Consumption Curves Comparison", agg_method='sum', show_error_bands=False, plot_global_consumption=False):
    """
    Generates and plots consumption curves for multiple specified consumer types
    on the same graph, with a given resampling frequency and aggregation method.
    Can also display error bands (standard deviation) and a global consumption curve.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        df_results (pd.DataFrame): DataFrame with 'id' as index and 'consumer_type' as a column.
        consumer_type_labels (list): A list of labels for the consumer types to plot (e.g., ['Principale', 'Secondaire']).
        resample_freq (str): The frequency to resample the data (e.g., 'h', 'D', 'W', 'M').
        colors (list, optional): A list of colors for each curve. If None, default Matplotlib colors are used.
        title (str): The title of the plot.
        agg_method (str): The aggregation method to apply during resampling (e.g., 'sum', 'mean', 'median', 'std').
        show_error_bands (bool): If True, plots shaded error bands representing the standard deviation.
        plot_global_consumption (bool): If True, plots an additional curve for the total consumption across all clients.
    """
    plt.figure(figsize=(14, 7))

    all_labels = list(consumer_type_labels)
    if plot_global_consumption:
        all_labels.append('Global Consumption')

    if colors is None:
        # Ensure enough colors for all curves, including global if plotted
        colors = [plt.cm.get_cmap('tab10')(i) for i in range(len(all_labels))]

    for i, current_label in enumerate(all_labels):
        if current_label == 'Global Consumption':
            # Calculate global consumption for the entire df_daily (filtered by weekly_df_daily in wrapper)
            aggregated_consumption_df = df_daily # Already filtered by the calling function
        else:
            target_ids = df_results[df_results['consumer_type'] == current_label].index.tolist()

            if not target_ids:
                print(f"No IDs found for consumer type: {current_label}")
                continue
            aggregated_consumption_df = df_daily.loc[target_ids]

        # Ensure columns are datetime for resampling
        try:
            aggregated_consumption_df.columns = pd.to_datetime(aggregated_consumption_df.columns)
        except Exception as e:
            print(f"Warning: Could not convert df_daily columns to datetime for resampling: {e}")

        # Stack to series, then convert index to datetime and resample
        consumption_series = aggregated_consumption_df.stack().rename('value')
        if isinstance(consumption_series.index, pd.MultiIndex):
            consumption_series.index = consumption_series.index.map(lambda x: x[1])
        consumption_series.index = pd.to_datetime(consumption_series.index)

        # Apply the chosen aggregation method
        resampled_data = consumption_series.resample(resample_freq)
        if agg_method == 'sum':
            resampled_consumption = resampled_data.sum()
        elif agg_method == 'mean':
            resampled_consumption = resampled_data.mean()
        elif agg_method == 'median':
            resampled_consumption = resampled_data.median()
        elif agg_method == 'std':
            resampled_consumption = resampled_data.std()
        else:
            print(f"Unsupported aggregation method: {agg_method}. Defaulting to sum.")
            resampled_consumption = resampled_data.sum()

        plt.plot(resampled_consumption.index, resampled_consumption.values,
                 label=f'{current_label} ({agg_method.capitalize()} {resample_freq})', color=colors[i])

        if show_error_bands and agg_method != 'std': # Cannot show error bands for std itself, it's the band itself
            std_dev = resampled_data.std()
            # Fill between mean - std and mean + std
            plt.fill_between(resampled_consumption.index,
                             (resampled_consumption - std_dev).fillna(resampled_consumption),
                             (resampled_consumption + std_dev).fillna(resampled_consumption),
                             color=colors[i], alpha=0.2, label=f'{current_label} \u00B11 Std Dev') # \u00B1 is for ± symbol

    plt.title(title)
    plt.xlabel('Date')
    plt.ylabel(f'{agg_method.capitalize()} Consumption (Value)')
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()


# --- Example Usage for comparison with mean aggregation and error bands---
print("Generating Mean Daily Consumption Comparison with Standard Deviation Error Bands:")
plot_multiple_consumption_curves_enhanced(
    df_daily,
    df_results,
    ['Principale', 'Secondaire'],
    resample_freq='D',
    colors=['blue', 'red'], # You can specify custom colors
    title="Daily Mean Consumption Comparison with Std Dev: Principal vs Secondary Residences",
    agg_method='mean',
    show_error_bands=True
)

print("\nGenerating Sum Weekly Consumption Comparison:")
# --- Example Usage for sum aggregation (original behavior but in new function) ---
plot_multiple_consumption_curves_enhanced(
    df_daily,
    df_results,
    ['Principale', 'Secondaire'],
    resample_freq='W',
    colors=['green', 'purple'],
    title="Weekly Sum Consumption Comparison: Principal vs Secondary Residences"
)
