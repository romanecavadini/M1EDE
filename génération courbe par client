# Plotting Consumption Curve for a Single Client
# To generate a consumption curve for an individual client, we'll create a dedicated function. This function will allow you to specify a particular client id and the desired resample_freq (e.g., 'H', 'D', 'W', 'M') to visualize their consumption pattern over time.

def plot_single_client_consumption(df_daily, client_id, resample_freq='D', title_suffix=""):
    """
    Generates and plots the consumption curve for a single client ID.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        client_id (int or str): The ID of the client for whom to plot the consumption.
        resample_freq (str): The frequency to resample the data (e.g., 'H', 'D', 'W', 'M').
        title_suffix (str): An optional suffix for the plot title.
    """
    if client_id not in df_daily.index:
        print(f"Client ID {client_id} not found in the data.")
        return

    # Select consumption data for the specific client
    # This will be a Series where the index is 'horodate' and values are consumption.
    single_client_consumption = df_daily.loc[client_id]

    # Ensure the index (horodate) is datetime for resampling
    single_client_consumption.index = pd.to_datetime(single_client_consumption.index)

    # Resample the consumption data
    resampled_consumption = single_client_consumption.resample(resample_freq).sum()

    # Plotting
    plt.figure(figsize=(12, 6))
    plt.plot(resampled_consumption.index, resampled_consumption.values)
    plt.title(f'Consumption Curve for Client {client_id} ({resample_freq} Aggregation) {title_suffix}')
    plt.xlabel('Date')
    plt.ylabel('Total Consumption (Value)')
    plt.grid(True)
    plt.tight_layout()
    plt.show()

# --- Example Usage for a single client ---
# Let's pick an example client ID from your df_daily index
example_client_id = df_daily.index[0] # Using the first client ID as an example

print(f"Plotting consumption for example client ID: {example_client_id}")
plot_single_client_consumption(df_daily, example_client_id, resample_freq='D', title_suffix="Daily")

# You can change `example_client_id` to any other ID present in your `df_daily` index
# and modify `resample_freq` (e.g., 'W' for weekly, 'M' for monthly) to see different aggregations.
