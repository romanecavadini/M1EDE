def plot_single_client_weekly_comparison(df_daily, df_results, client_id, start_date_str, resample_freq='D', title_prefix="Weekly Consumption Comparison"):
    """
    Plots the consumption curve for a single client and compares it to the average
    consumption of their assigned consumer type, for a specific week.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        df_results (pd.DataFrame): DataFrame with 'id' as index and 'consumer_type' as a column.
        client_id (int or str): The ID of the client for whom to plot the consumption.
        start_date_str (str): The start date of the week to plot (e.g., 'YYYY-MM-DD').
        resample_freq (str): The frequency to resample the data (e.g., 'H', 'D', 'W', 'M').
        title_prefix (str): A prefix for the plot title.
    """
    if client_id not in df_daily.index:
        print(f"Client ID {client_id} not found in the data.")
        return

    if client_id not in df_results.index:
        print(f"Client ID {client_id} not found in df_results to determine consumer type.")
        return

    consumer_type_label = df_results.loc[client_id, 'consumer_type']

    # Define the week period, ensuring timezone awareness
    start_date = pd.to_datetime(start_date_str).tz_localize('UTC')
    end_date = start_date + pd.Timedelta(weeks=1)

    # Filter df_daily for the specified week
    weekly_df_daily = df_daily.loc[:, (df_daily.columns >= start_date) & (df_daily.columns < end_date)]

    if weekly_df_daily.empty:
        print(f"No data found for the week starting {start_date_str}. Please choose a different date.")
        return

    # Get single client consumption for the week
    single_client_weekly_consumption = weekly_df_daily.loc[client_id]
    single_client_weekly_consumption.index = pd.to_datetime(single_client_weekly_consumption.index)
    resampled_client_consumption = single_client_weekly_consumption.resample(resample_freq).sum()

    # Get average consumption for the client's consumer type for the week
    target_ids = df_results[df_results['consumer_type'] == consumer_type_label].index.tolist()
    # Exclude the current client from the average to make it a true group average
    target_ids_for_avg = [idx for idx in target_ids if idx != client_id]

    if not target_ids_for_avg:
        print(f"Cannot calculate average for type {consumer_type_label} without other clients for this week.")
        return

    type_average_weekly_consumption_df = weekly_df_daily.loc[target_ids_for_avg]

    # Stack to series, then convert index to datetime and resample
    type_avg_consumption_series = type_average_weekly_consumption_df.stack().rename('value')
    if isinstance(type_avg_consumption_series.index, pd.MultiIndex):
        type_avg_consumption_series.index = type_avg_consumption_series.index.map(lambda x: x[1])
    type_avg_consumption_series.index = pd.to_datetime(type_avg_consumption_series.index)

    resampled_type_average = type_avg_consumption_series.resample(resample_freq).mean()

    # Plotting
    plt.figure(figsize=(14, 7))
    plt.plot(resampled_client_consumption.index, resampled_client_consumption.values,
             label=f'Client {client_id} (Type: {consumer_type_label})', color='blue', alpha=0.8)
    plt.plot(resampled_type_average.index, resampled_type_average.values,
             label=f'Average {consumer_type_label} Type', color='red', linestyle='--', alpha=0.7)

    plt.title(f"{title_prefix}: Client {client_id} vs. {consumer_type_label} Type Average ({resample_freq} Aggregation) {start_date.strftime('%Y-%m-%d')} to {(end_date - pd.Timedelta(days=1)).strftime('%Y-%m-%d')}")
    plt.xlabel('Date')
    plt.ylabel('Consumption (Value)')
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()

