# --- Example Usage for a single client weekly comparison ---
example_client_id = df_daily.index[0] # Using the first client ID as an example

print(f"\nPlotting weekly consumption for client {example_client_id} against their type average:")
plot_single_client_weekly_comparison(
    df_daily,
    df_results,
    example_client_id,
    start_date_str='2023-11-01', # Change this to any week's start date
    resample_freq='h' # 'h' for hourly, 'D' for daily
)

