# Générateur de Courbes de Consommation Synthétiques (Approche Statistique)
# Nous allons maintenant créer un générateur de courbes de consommation conditionnel au type de consommateur (Résidence Principale ou Résidence Secondaire).

# L'approche statistique consistera à :

# Identifier les courbes de consommation réelles pour chaque type de consommateur (RP et RS).
# Calculer le profil moyen de consommation journalière et la variabilité (écart-type) pour chaque type.
# Générer de nouvelles courbes en ajoutant un bruit aléatoire (issu d'une distribution normale avec l'écart-type observé) au profil moyen. Cela permet de créer des courbes uniques qui conservent les caractéristiques statistiques de leur type.
# Le pas temporel choisi sera journalier, correspondant à la granularité de df_daily.

import matplotlib.pyplot as plt

def generate_synthetic_curves(df_daily, df_results, consumer_type, num_curves=5, random_seed=42):
    """
    Génère des courbes de consommation synthétiques pour un type de consommateur donné.

    Args:
        df_daily (pd.DataFrame): DataFrame des consommations journalières (id x dates).
        df_results (pd.DataFrame): DataFrame avec l'affectation 'prediction_binaire' pour chaque id.
        consumer_type (int): 0 pour Résidence Principale, 1 pour Résidence Secondaire.
        num_curves (int): Nombre de courbes synthétiques à générer.
        random_seed (int): Graine pour la reproductibilité.

    Returns:
        pd.DataFrame: DataFrame contenant les courbes synthétiques.
    """
    np.random.seed(random_seed)

    # Joindre df_daily avec les prédictions de type de consommateur
    df_daily_classified = df_daily.merge(df_results['prediction_binaire'], left_index=True, right_index=True)

    # Filtrer les données pour le type de consommateur spécifié
    df_filtered = df_daily_classified[df_daily_classified['prediction_binaire'] == consumer_type].drop(columns=['prediction_binaire'])

    if df_filtered.empty:
        print(f"Aucune donnée réelle trouvée pour le type de consommateur {consumer_type}.")
        return pd.DataFrame()

    # Calculer le profil moyen et l'écart-type journalier pour ce type
    mean_profile = df_filtered.mean(axis=0)
    std_profile = df_filtered.std(axis=0)

    # S'assurer que les dates sont des colonnes pour le DataFrame de sortie
    dates = df_filtered.columns

    # Générer des courbes synthétiques
    synthetic_data = []
    for i in range(num_curves):
        # Ajouter un bruit aléatoire au profil moyen
        synthetic_curve = mean_profile + np.random.normal(0, std_profile, size=len(mean_profile))
        # S'assurer que les valeurs de consommation ne sont pas négatives
        synthetic_curve = np.maximum(0, synthetic_curve)
        synthetic_data.append(synthetic_curve)

    # Créer un DataFrame à partir des courbes générées
    synthetic_df = pd.DataFrame(synthetic_data, columns=dates)
    synthetic_df.index = [f'synthetic_id_{consumer_type}_{i}' for i in range(num_curves)]
    
    return synthetic_df

# --- Démonstration et Vérification --- 

# Génération de courbes pour les Résidences Principales (RP)
print("\n--- Génération de courbes pour les Résidences Principales (0) ---")
synthetic_rp_curves = generate_synthetic_curves(df_daily, df_results, consumer_type=0, num_curves=10)
if not synthetic_rp_curves.empty:
    print(f"Généré {len(synthetic_rp_curves)} courbes RP synthétiques.")
    display(synthetic_rp_curves.head())

# Génération de courbes pour les Résidences Secondaires (RS)
print("\n--- Génération de courbes pour les Résidences Secondaires (1) ---")
synthetic_rs_curves = generate_synthetic_curves(df_daily, df_results, consumer_type=1, num_curves=10)
if not synthetic_rs_curves.empty:
    print(f"Généré {len(synthetic_rs_curves)} courbes RS synthétiques.")
    display(synthetic_rs_curves.head())

