#Compare Consumption Curves for Multiple Consumer Types
#To directly compare the consumption patterns of 'Principale' and 'Secondaire' residences, we can plot their curves on the same graph. The function below allows you to specify a list of consumer types and a resample_freq to visualize their aggregated consumption together.

def plot_multiple_consumption_curves(df_daily, df_results, consumer_type_labels, resample_freq='D', colors=None, title="Consumption Curves Comparison"):
    """
    Generates and plots consumption curves for multiple specified consumer types
    on the same graph, with a given resampling frequency.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        df_results (pd.DataFrame): DataFrame with 'id' as index and 'consumer_type' as a column.
        consumer_type_labels (list): A list of labels for the consumer types to plot (e.g., ['Principale', 'Secondaire']).
        resample_freq (str): The frequency to resample the data (e.g., 'H', 'D', 'W', 'M').
        colors (list, optional): A list of colors for each curve. If None, default Matplotlib colors are used.
        title (str): The title of the plot.
    """
    plt.figure(figsize=(14, 7))
    if colors is None:
        colors = plt.cm.get_cmap('tab10', len(consumer_type_labels))

    for i, consumer_type_label in enumerate(consumer_type_labels):
        target_ids = df_results[df_results['consumer_type'] == consumer_type_label].index.tolist()

        if not target_ids:
            print(f"No IDs found for consumer type: {consumer_type_label}")
            continue

        aggregated_consumption = df_daily.loc[target_ids].sum(axis=0)
        aggregated_consumption.index = pd.to_datetime(aggregated_consumption.index)
        resampled_consumption = aggregated_consumption.resample(resample_freq).sum()

        plt.plot(resampled_consumption.index, resampled_consumption.values,
                 label=f'{consumer_type_label} ({resample_freq})', color=colors(i) if callable(colors) else colors[i])

    plt.title(title)
    plt.xlabel('Date')
    plt.ylabel('Total Consumption (Value)')
    plt.grid(True)
    plt.legend()
    plt.tight_layout()
    plt.show()


# --- Example Usage for comparison ---
plot_multiple_consumption_curves(
    df_daily,
    df_results,
    ['Principale', 'Secondaire'],
    resample_freq='D',
    colors=['blue', 'red'], # You can specify custom colors
    title="Daily Consumption Comparison: Principal vs Secondary Residences"
)


#You can now easily compare the two consumer types. Feel free to modify the resample_freq (e.g., 'W' for weekly, 'M' for monthly) or experiment with different colors or title values in the function call above to further customize your comparison!
