#Generating Consumption Curves by Consumer Type
#First, I will merge the clustering results with the daily aggregated consumption data (df_daily) to associate each household with its predicted type (Principal or Secondary residence). Then, I'll define a function to plot the consumption curves, allowing for a flexible time granularity.

# Map cluster assignments to consumer types (Principale/Secondaire)
# The 'cluster_to_class' dictionary defines this mapping from the previous step.

df_results['consumer_type'] = df_results['prediction_binaire'].map({0: 'Principale', 1: 'Secondaire'})

# df_daily has 'id' as index and 'horodate' as columns.
# df_results['consumer_type'] has 'id' as index.
# We need to use these directly in the plotting function to aggregate consumption by type.

# Now, let's define a function to generate and plot the consumption curves. This function will allow you to specify the consumer type and the desired resampling frequency (e.g., 'H' for hourly, 'D' for daily, 'W' for weekly, 'M' for monthly)

def plot_consumption_curve(df_daily, df_results, consumer_type_label, resample_freq='D', title_suffix=""):
    """
    Generates and plots a consumption curve for a specific consumer type
    with a given resampling frequency.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        df_results (pd.DataFrame): DataFrame with 'id' as index and 'consumer_type' as a column.
        consumer_type_label (str): The label for the consumer type ('Principale' or 'Secondaire').
        resample_freq (str): The frequency to resample the data (e.g., 'H', 'D', 'W', 'M').
        title_suffix (str): An optional suffix for the plot title.
    """
    # Get IDs for the specified consumer type
    target_ids = df_results[df_results['consumer_type'] == consumer_type_label].index.tolist()

    if not target_ids:
        print(f"No IDs found for consumer type: {consumer_type_label}")
        return

    # Select consumption data for these IDs from df_daily and sum across them
    # df_daily has 'id' as index, 'horodate' as columns. Summing across axis=0 (ids) 
    # results in a Series indexed by horodate.
    aggregated_consumption = df_daily.loc[target_ids].sum(axis=0)

    # Ensure the index (horodate) is datetime for resampling
    aggregated_consumption.index = pd.to_datetime(aggregated_consumption.index)

    # Resample the aggregated consumption
    resampled_consumption = aggregated_consumption.resample(resample_freq).sum()

    # Plotting
    plt.figure(figsize=(12, 6))
    plt.plot(resampled_consumption.index, resampled_consumption.values)
    plt.title(f'Consumption Curve for {consumer_type_label} ({resample_freq} Aggregation) {title_suffix}')
    plt.xlabel('Date')
    plt.ylabel('Total Consumption (Value)')
    plt.grid(True)
    plt.tight_layout()
    plt.show()


# --- Example Usage ---
# Plot daily consumption for 'Principale' residences
plot_consumption_curve(df_daily, df_results, 'Principale', resample_freq='D', title_suffix="Daily")

# Plot daily consumption for 'Secondaire' residences
plot_consumption_curve(df_daily, df_results, 'Secondaire', resample_freq='D', title_suffix="Daily")

You can easily change the resample_freq parameter in the plot_consumption_curve function to view the curves at different time granularities. For example:

resample_freq='H' for hourly data
resample_freq='W' for weekly data
resample_freq='M' for monthly data
