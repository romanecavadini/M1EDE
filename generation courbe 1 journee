# Courbe de Consommation d'un Client pour une Journée Spécifique
# Cette fonction permet de visualiser la consommation horaire d'un client unique sur une journée particulière. C'est utile pour analyser les profils de consommation détaillés sans agrégation sur des périodes plus longues.

import matplotlib.pyplot as plt
import pandas as pd

def plot_single_client_daily_consumption(df_daily, client_id, target_date_str, title_suffix=""):
    """
    Plots the consumption curve for a single client for a specific day.

    Args:
        df_daily (pd.DataFrame): DataFrame with 'id' as index and 'horodate' as columns (consumption values).
        client_id (int or str): The ID of the client for whom to plot the consumption.
        target_date_str (str): The specific date to plot (e.g., 'YYYY-MM-DD').
        title_suffix (str): An optional suffix for the plot title.
    """
    if client_id not in df_daily.index:
        print(f"Client ID {client_id} not found in the data.")
        return

    try:
        # Localize target_date to UTC to match df_daily columns
        target_date = pd.to_datetime(target_date_str).normalize().tz_localize('UTC')
    except Exception as e:
        print(f"Invalid date format for target_date_str: {e}")
        return

    # Define the start and end of the target day
    day_start = target_date
    day_end = target_date + pd.Timedelta(days=1)

    # Filter df_daily for the specific client
    client_consumption_series = df_daily.loc[client_id]

    # Ensure column index is datetime and then filter for the target day
    client_consumption_series.index = pd.to_datetime(client_consumption_series.index)
    daily_consumption = client_consumption_series[(client_consumption_series.index >= day_start) & (client_consumption_series.index < day_end)]

    if daily_consumption.empty:
        print(f"No consumption data found for client {client_id} on {target_date_str}.")
        return

    # Plotting
    plt.figure(figsize=(12, 6))
    plt.plot(daily_consumption.index, daily_consumption.values, marker='o', linestyle='-')
    plt.title(f'Hourly Consumption for Client {client_id} on {target_date_str} {title_suffix}')
    plt.xlabel('Time of Day')
    plt.ylabel('Consumption (Value)')
    plt.grid(True)
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()

# Modifiez l'ID du client que vous souhaitez analyser.
# Pour trouver des IDs existants, vous pouvez regarder `df_daily.index.tolist()`
client_id_for_daily_plot = df_daily.index[1] # Exemple: utilise le deuxième ID de client

# Modifiez la date spécifique que vous souhaitez analyser (YYYY-MM-DD)
target_date_for_daily_plot = '2023-11-01' # Exemple: 1er novembre 2023

print(f"Génération de la courbe de consommation horaire pour le client {client_id_for_daily_plot} pour la journée du {target_date_for_daily_plot}:")

plot_single_client_daily_consumption(
    df_daily,
    client_id_for_daily_plot,
    target_date_for_daily_plot,
    title_suffix="Hourly Detail"
)

print("\nN'hésitez pas à modifier `client_id_for_daily_plot` et `target_date_for_daily_plot` pour explorer d'autres clients et journées spécifiques !")
