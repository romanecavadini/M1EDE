def sigmoid(z):
    return 1 / (1 + np.exp(-z))

def fit_logistic_regression(X, y, lr=0.01, n_iter=1000):
    n, p = X.shape
    beta = np.zeros(p)

    for i in range(n_iter):
        p_hat = sigmoid(X @ beta)
        gradient = X.T @ (p_hat - y) / n
        beta -= lr * gradient

    return beta

def predict(X, beta, threshold=0.5):
    proba = sigmoid(X @ beta)
    return (proba >= threshold).astype(int)

