# Génération d'Indicateurs pour Analyser les Différences
# Pour mieux comprendre les similitudes et les différences entre les courbes réelles et synthétiques, nous allons calculer plusieurs indicateurs statistiques clés pour chaque groupe (Résidences Principales réelles, Résidences Secondaires réelles, Résidences Principales synthétiques, Résidences Secondaires synthétiques).

# Ces indicateurs incluront des mesures de tendance centrale, de dispersion et des extrêmes, pour évaluer la cohérence globale des données générées.

def calculate_consumption_indicators(df, name="Data"):
    """
    Calcule des indicateurs statistiques pour un DataFrame de courbes de consommation journalière.

    Args:
        df (pd.DataFrame): DataFrame des consommations journalières (id x dates).
        name (str): Nom à associer à cet ensemble de données dans les résultats.

    Returns:
        pd.Series: Série pandas contenant les indicateurs calculés.
    """
    if df.empty:
        return pd.Series(dtype='float64')

    total_consumption_per_id = df.sum(axis=1)

    # Indicateurs par courbe (par 'id')
    mean_conso_per_id = total_consumption_per_id.mean()
    std_conso_per_id = total_consumption_per_id.std()
    min_conso_per_id = total_consumption_per_id.min()
    max_conso_per_id = total_consumption_per_id.max()
    q25_conso_per_id = total_consumption_per_id.quantile(0.25)
    q75_conso_per_id = total_consumption_per_id.quantile(0.75)

    # Indicateurs agrégés sur toutes les courbes pour chaque jour
    daily_mean_across_ids = df.mean(axis=0).mean() # Moyenne de la moyenne journalière
    daily_std_across_ids = df.std(axis=0).mean()   # Moyenne de l'écart-type journalier

    return pd.Series({
        'Type': name,
        'Moyenne Conso Totale (par ID)': mean_conso_per_id,
        'Ecart-type Conso Totale (par ID)': std_conso_per_id,
        'Min Conso Totale (par ID)': min_conso_per_id,
        'Max Conso Totale (par ID)': max_conso_per_id,
        'Q25 Conso Totale (par ID)': q25_conso_per_id,
        'Q75 Conso Totale (par ID)': q75_conso_per_id,
        'Moyenne Journalière (globale)': daily_mean_across_ids,
        'Ecart-type Journalier (globale)': daily_std_across_ids
    })

# --- Préparation des données réelles classifiées ---
df_daily_classified = df_daily.merge(df_results['prediction_binaire'], left_index=True, right_index=True)

rp_real_data = df_daily_classified[df_daily_classified['prediction_binaire'] == 0].drop(columns=['prediction_binaire'])
rs_real_data = df_daily_classified[df_daily_classified['prediction_binaire'] == 1].drop(columns=['prediction_binaire'])

# --- Calcul des indicateurs ---
indicators = []

indicators.append(calculate_consumption_indicators(rp_real_data, name='Réel RP'))
indicators.append(calculate_consumption_indicators(rs_real_data, name='Réel RS'))
indicators.append(calculate_consumption_indicators(synthetic_rp_curves, name='Synthétique RP'))
